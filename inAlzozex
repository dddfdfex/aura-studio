/* ═══ PRELOADER ═══ */
#preloader{position:fixed;inset:0;z-index:99999;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;transition:opacity 1.4s var(--ease2),visibility 1.4s var(--ease2)}
#preloader.gone{opacity:0;visibility:hidden;pointer-events:none}
.pre-orb{position:absolute;width:340px;height:340px;border-radius:50%;background:radial-gradient(circle,rgba(110,231,255,.04) 0%,transparent 70%);animation:preOrbPulse 2.5s ease-in-out infinite}
@keyframes preOrbPulse{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.15);opacity:1}}
.pre-scan-line{position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);box-shadow:0 0 40px 8px rgba(110,231,255,.08);animation:preScan 2.6s var(--ease2) forwards;top:-1px}
@keyframes preScan{from{top:-1px}to{top:calc(100% + 1px)}}
.pre-center{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:0;animation:preIn 1s var(--ease2) .2s both}
@keyframes preIn{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:none}}
.pre-logo-aura{width:110px;height:110px;border-radius:50%;border:1px solid rgba(110,231,255,.08);display:flex;align-items:center;justify-content:center;position:relative;animation:preLogoGlow 3s ease-in-out .8s infinite}
@keyframes preLogoGlow{0%,100%{box-shadow:0 0 30px rgba(110,231,255,.08)}50%{box-shadow:0 0 80px rgba(110,231,255,.2)}}
.pre-logo-aura::before,.pre-logo-aura::after{content:'';position:absolute;border-radius:50%;border:1px solid rgba(110,231,255,.04)}
.pre-logo-aura::before{inset:-14px;animation:ringSpin 6s linear infinite}
.pre-logo-aura::after{inset:-28px;animation:ringSpin 9s linear infinite reverse}
@keyframes ringSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.pre-logo-svg{width:60px;height:60px}
.pre-name{font-family:var(--font-en);font-size:22px;font-weight:700;letter-spacing:8px;color:var(--white);margin-top:28px;text-transform:uppercase}
.pre-sub{font-family:var(--font-mono);font-size:8px;letter-spacing:5px;color:rgba(110,231,255,.5);text-transform:uppercase;margin-top:6px}
.pre-bar-wrap{width:260px;margin-top:44px;animation:preFadeUp .8s var(--ease2) .9s both}
@keyframes preFadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
.pre-track{height:1px;background:rgba(255,255,255,.04);border-radius:1px;overflow:hidden;position:relative}
.pre-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--glow),var(--accent),#fff);transition:width .04s linear;position:relative}
.pre-fill::after{content:'';position:absolute;right:-1px;top:-3px;width:1px;height:7px;background:var(--white);box-shadow:0 0 12px 3px rgba(110,231,255,.6)}
.pre-num-wrap{display:flex;justify-content:space-between;margin-top:10px;align-items:center}
.pre-pct{font-family:var(--font-mono);font-size:9px;color:var(--accent);letter-spacing:3px}
.pre-status{font-family:var(--font-mono);font-size:7px;color:rgba(255,255,255,.18);letter-spacing:2px;text-transform:uppercase}

/* ═══ NAV ═══ */
nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:16px 60px;display:flex;align-items:center;justify-content:space-between;transition:all .5s var(--ease2);background:transparent;backdrop-filter:blur(0px)}
nav.scrolled{background:rgba(5,5,5,.92);border-bottom:1px solid var(--border);backdrop-filter:blur(30px);padding:12px 60px}
.nav-logo{display:flex;align-items:center;gap:14px;text-decoration:none}
.nav-logo-icon{width:42px;height:42px;border-radius:50%;border:1px solid rgba(110,231,255,.08);display:flex;align-items:center;justify-content:center;position:relative;transition:all .4s var(--ease2)}
.nav-logo-icon:hover{border-color:var(--border2);box-shadow:var(--glow-sm)}
.nav-logo-text{display:flex;flex-direction:column;gap:0}
.nav-logo-name{font-family:var(--font-en);font-size:16px;font-weight:700;letter-spacing:3px;color:var(--white);text-transform:uppercase}
.nav-logo-tag{font-family:var(--font-mono);font-size:6px;letter-spacing:3px;color:rgba(110,231,255,.4);text-transform:uppercase}
.nav-links{display:flex;align-items:center;gap:40px;list-style:none}
.nav-links a{font-family:var(--font-en);font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.22);transition:color .3s;position:relative;padding-bottom:5px}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);transform:scaleX(0);transform-origin:center;transition:transform .4s var(--ease2)}
.nav-links a:hover{color:var(--white)}
.nav-links a:hover::after{transform:scaleX(1)}
.nav-right{display:flex;align-items:center;gap:12px}
.lang-btn{display:flex;align-items:center;gap:7px;padding:8px 18px;border:1px solid var(--border);background:transparent;color:rgba(255,255,255,.3);font-family:var(--font-en);font-size:8px;letter-spacing:2.5px;text-transform:uppercase;transition:all .3s;border-radius:30px}
.lang-btn:hover{border-color:var(--border2);color:var(--white);background:rgba(110,231,255,.03)}
.nav-cta-btn{padding:10px 26px;border:1px solid var(--accent);background:transparent;color:var(--accent);font-family:var(--font-en);font-size:9px;letter-spacing:2.5px;text-transform:uppercase;transition:all .35s var(--ease2);border-radius:30px;position:relative;overflow:hidden}
.nav-cta-btn::before{content:'';position:absolute;inset:0;background:var(--accent);transform:translateX(-101%);transition:transform .4s var(--ease2)}
.nav-cta-btn:hover::before{transform:translateX(0)}
.nav-cta-btn:hover{color:var(--bg)}
.nav-cta-btn span{position:relative;z-index:1}
.hamburger{display:none;flex-direction:column;gap:5px;width:36px;height:36px;border:1px solid var(--border);background:transparent;border-radius:10px;align-items:center;justify-content:center}
.hamburger span{display:block;width:18px;height:1px;background:rgba(255,255,255,.4);transition:all .3s}
.hamburger.open span:nth-child(1){transform:rotate(45deg) translate(4px,4px)}
.hamburger.open span:nth-child(2){opacity:0}
.hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(4px,-4px)}

/* ═══ MOBILE MENU ═══ */
#mob-menu{position:fixed;inset:0;z-index:199;background:rgba(5,5,5,.98);backdrop-filter:blur(30px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;opacity:0;visibility:hidden;transition:opacity .5s var(--ease2),visibility .5s}
#mob-menu.open{opacity:1;visibility:visible}
.mob-link{font-family:var(--font-en);font-size:clamp(22px,5vw,32px);letter-spacing:6px;text-transform:uppercase;color:rgba(255,255,255,.3);transition:all .35s;padding:8px 0}
.mob-link:hover{color:var(--white);text-shadow:var(--glow-md)}

/* ═══ HERO ═══ */
#hero{position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:0 24px;overflow:hidden;z-index:2}
.hero-bg-orb{position:absolute;width:900px;height:900px;border-radius:50%;background:radial-gradient(circle,rgba(110,231,255,.04) 0%,transparent 65%);pointer-events:none;animation:heroOrbFloat 8s ease-in-out infinite alternate}
@keyframes heroOrbFloat{0%{transform:translate(-20px,-20px) scale(1)}100%{transform:translate(20px,20px) scale(1.06)}}
.hero-grid-line{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.008) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.008) 1px,transparent 1px);background-size:80px 80px;animation:gridFade 6s ease-in-out infinite alternate;pointer-events:none}
@keyframes gridFade{0%{opacity:.3}100%{opacity:.7}}
.hero-inner{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:0}
.hero-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:32px;animation:fadeUp 1s var(--ease2) .2s both}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
.hero-eyebrow-line{width:32px;height:1px;background:linear-gradient(90deg,transparent,var(--accent))}
.hero-eyebrow-text{font-family:var(--font-mono);font-size:8px;letter-spacing:5px;color:var(--accent);text-transform:uppercase}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:8px 20px;border:1px solid var(--border);border-radius:30px;margin-bottom:32px;animation:fadeUp 1s var(--ease2) .4s both;background:rgba(110,231,255,.02)}
.hero-badge-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);animation:badgeDot 2s ease-in-out infinite}
@keyframes badgeDot{0%,100%{box-shadow:0 0 0 0 rgba(110,231,255,.4)}50%{box-shadow:0 0 0 6px rgba(110,231,255,0)}}
.hero-badge-text{font-family:var(--font-mono);font-size:8px;letter-spacing:3px;color:rgba(255,255,255,.4);text-transform:uppercase}
.hero-logo-orbit{position:relative;width:200px;height:200px;display:flex;align-items:center;justify-content:center;margin-bottom:40px;animation:fadeUp 1.2s var(--ease2) .1s both}
.hero-orbit-ring{position:absolute;border-radius:50%;border:1px dashed rgba(110,231,255,.06)}
.hero-orbit-ring:nth-child(1){inset:0;animation:orbitSpin 12s linear infinite}
.hero-orbit-ring:nth-child(2){inset:-20px;animation:orbitSpin 18s linear infinite reverse;border-style:solid;border-color:rgba(110,231,255,.03)}
.hero-orbit-ring:nth-child(3){inset:-40px;animation:orbitSpin 25s linear infinite;border-style:dashed;border-color:rgba(110,231,255,.02)}
@keyframes orbitSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.hero-orbit-dot{position:absolute;width:6px;height:6px;border-radius:50%;background:var(--accent);top:-3px;left:50%;transform:translateX(-50%);box-shadow:0 0 16px 4px rgba(110,231,255,.4)}
.hero-logo-center{width:140px;height:140px;border-radius:50%;border:1px solid rgba(110,231,255,.1);display:flex;align-items:center;justify-content:center;animation:heroLogoGlow 4s ease-in-out infinite;position:relative;z-index:1}
@keyframes heroLogoGlow{0%,100%{box-shadow:0 0 40px rgba(110,231,255,.08)}50%{box-shadow:0 0 100px rgba(110,231,255,.18)}}
.hero-logo-center svg{width:72px;height:72px}
.hero-title{font-size:clamp(52px,9vw,110px);font-weight:800;letter-spacing:-5px;line-height:.95;color:var(--white);animation:heroTitleIn 1.4s var(--ease2) .3s both;margin-bottom:0}
@keyframes heroTitleIn{from{opacity:0;transform:translateY(40px) skewY(3deg)}to{opacity:1;transform:none}}
.hero-title-accent{background:linear-gradient(135deg,var(--accent),var(--glow),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:clamp(14px,2vw,18px);color:rgba(255,255,255,.3);max-width:600px;margin:24px auto 0;animation:fadeUp 1s var(--ease2) .6s both;line-height:1.9}
.hero-btns{display:flex;align-items:center;gap:16px;margin-top:44px;animation:fadeUp 1s var(--ease2) .8s both;flex-wrap:wrap;justify-content:center}
.btn-primary{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;background:var(--accent);color:var(--bg);font-family:var(--font-en);font-size:10px;letter-spacing:3px;text-transform:uppercase;border:none;border-radius:40px;font-weight:700;transition:all .4s var(--ease2);position:relative;overflow:hidden}
.btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--glow),var(--accent));opacity:0;transition:opacity .3s}
.btn-primary:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 20px 60px rgba(110,231,255,.3)}
.btn-primary:hover::before{opacity:1}
.btn-primary span,.btn-primary svg{position:relative;z-index:1}
.btn-ghost{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;border:1px solid rgba(255,255,255,.08);color:rgba(255,255,255,.5);font-family:var(--font-en);font-size:10px;letter-spacing:3px;text-transform:uppercase;background:transparent;border-radius:40px;transition:all .4s var(--ease2)}
.btn-ghost:hover{border-color:rgba(255,255,255,.2);color:var(--white);transform:translateY(-2px)}
.hero-scroll-hint{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;animation:fadeUp 1s var(--ease2) 1.2s both}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,transparent,rgba(110,231,255,.3),transparent);animation:scrollLine 2s ease-in-out infinite}
@keyframes scrollLine{0%,100%{opacity:.3;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.2)}}
.scroll-text{font-family:var(--font-mono);font-size:7px;letter-spacing:4px;color:rgba(255,255,255,.15);text-transform:uppercase}
.hero-stats{display:flex;align-items:center;gap:40px;margin-top:60px;animation:fadeUp 1s var(--ease2) 1s both;flex-wrap:wrap;justify-content:center}
.hero-stat{display:flex;flex-direction:column;align-items:center;gap:4px}
.hero-stat-num{font-family:var(--font-en);font-size:28px;font-weight:700;color:var(--white);line-height:1}
.hero-stat-label{font-family:var(--font-mono);font-size:7px;letter-spacing:3px;color:rgba(255,255,255,.2);text-transform:uppercase}
.hero-stat-div{width:1px;height:36px;background:rgba(255,255,255,.06)}

/* ═══ SECTION BASE ═══ */
.section{position:relative;z-index:2;padding:140px 72px}
.section-sep{height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);margin:0 72px;position:relative;z-index:2}
.s-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:16px}
.s-eyebrow-line{width:28px;height:1px;background:linear-gradient(90deg,transparent,var(--accent))}
html[dir="ltr"] .s-eyebrow-line{background:linear-gradient(90deg,var(--accent),transparent)}
.s-eyebrow-text{font-family:var(--font-mono);font-size:7px;letter-spacing:5px;color:var(--accent);text-transform:uppercase}
.s-title{font-size:clamp(28px,4vw,52px);font-weight:800;color:var(--white);line-height:1.1;letter-spacing:-2px;margin-bottom:16px}
.s-sub{font-size:clamp(13px,1.5vw,16px);color:rgba(255,255,255,.25);max-width:560px;line-height:1.9}

/* ═══ REVEAL ANIMATIONS ═══ */
.reveal{opacity:0;transform:translateY(32px);transition:opacity .8s var(--ease2),transform .8s var(--ease2)}
.reveal.visible{opacity:1;transform:none}
.reveal-l{opacity:0;transform:translateX(-40px);transition:opacity .8s var(--ease2),transform .8s var(--ease2)}
.reveal-l.visible{opacity:1;transform:none}
.reveal-r{opacity:0;transform:translateX(40px);transition:opacity .8s var(--ease2),transform .8s var(--ease2)}
.reveal-r.visible{opacity:1;transform:none}
.reveal-scale{opacity:0;transform:scale(.92);transition:opacity .8s var(--ease2),transform .8s var(--ease2)}
.reveal-scale.visible{opacity:1;transform:none}

/* ═══ INTRO STATEMENT ═══ */
#intro{padding:160px 72px;text-align:center}
.intro-tagline{font-size:clamp(8px,1vw,10px);letter-spacing:6px;color:rgba(110,231,255,.4);font-family:var(--font-mono);text-transform:uppercase;margin-bottom:32px;display:block}
.intro-statement{font-size:clamp(26px,4.5vw,60px);font-weight:700;color:var(--white);line-height:1.3;max-width:900px;margin:0 auto;letter-spacing:-1px}
.intro-statement em{font-style:normal;background:linear-gradient(135deg,var(--accent),var(--glow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.intro-divider{width:1px;height:100px;background:linear-gradient(to bottom,transparent,var(--accent),transparent);margin:60px auto;opacity:.3}

/* ═══ SERVICES ═══ */
#services{padding:140px 72px}
.services-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:72px;gap:32px;flex-wrap:wrap}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
.svc-card{background:var(--bg2);border:1px solid var(--border);padding:40px 32px;position:relative;overflow:hidden;transition:all .5s var(--ease2);cursor:none;min-height:280px;display:flex;flex-direction:column;justify-content:space-between}
.svc-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 80% at var(--mx,50%) var(--my,50%),rgba(110,231,255,.05) 0%,transparent 60%);opacity:0;transition:opacity .4s}
.svc-card:hover::before{opacity:1}
.svc-card::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);transform:scaleX(0);transition:transform .5s var(--ease2)}
.svc-card:hover::after{transform:scaleX(1)}
.svc-card:hover{transform:translateY(-4px);border-color:var(--border2);box-shadow:var(--glow-sm)}
.svc-num{font-family:var(--font-mono);font-size:8px;letter-spacing:3px;color:rgba(110,231,255,.25);margin-bottom:32px}
.svc-icon{width:48px;height:48px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;position:relative}
.svc-icon svg{width:28px;height:28px;stroke:var(--accent);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:all .4s var(--ease2)}
.svc-card:hover .svc-icon svg{filter:drop-shadow(0 0 12px rgba(110,231,255,.5));transform:scale(1.1)}
.svc-icon::before{content:'';position:absolute;inset:0;border-radius:12px;background:rgba(110,231,255,.04);border:1px solid var(--border);transition:all .4s}
.svc-card:hover .svc-icon::before{background:rgba(110,231,255,.08);border-color:var(--border2)}
.svc-title{font-size:15px;font-weight:600;color:var(--white);margin-bottom:12px;transition:color .3s}
.svc-card:hover .svc-title{color:var(--accent)}
.svc-desc{font-size:12px;color:rgba(255,255,255,.2);line-height:1.8;flex:1}
.svc-arrow{width:28px;height:28px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-top:24px;transition:all .35s var(--ease2);align-self:flex-start}
.svc-arrow svg{width:12px;height:12px;stroke:rgba(255,255,255,.25);fill:none;stroke-width:2}
.svc-card:hover .svc-arrow{border-color:var(--accent);background:rgba(110,231,255,.08)}
.svc-card:hover .svc-arrow svg{stroke:var(--accent)}

/* ═══ AURA AI SYSTEM ═══ */
#ai-system{padding:140px 72px;background:var(--bg2)}
.ai-system-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.ai-panel{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:40px;position:relative;overflow:hidden}
.ai-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.ai-panel-header{display:flex;align-items:center;gap:12px;margin-bottom:28px}
.ai-status-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);animation:aiDotPulse 2s ease-in-out infinite}
@keyframes aiDotPulse{0%,100%{box-shadow:0 0 0 0 rgba(110,231,255,.4)}50%{box-shadow:0 0 0 8px rgba(110,231,255,0)}}
.ai-panel-title{font-family:var(--font-mono);font-size:9px;letter-spacing:4px;color:rgba(110,231,255,.6);text-transform:uppercase}
.ai-terminal{font-family:var(--font-mono);font-size:11px;line-height:2;color:rgba(255,255,255,.25)}
.ai-terminal .cmd{color:var(--accent)}
.ai-terminal .out{color:rgba(255,255,255,.4)}
.ai-terminal .dim{color:rgba(255,255,255,.12)}
.ai-type-cards{display:flex;flex-direction:column;gap:10px;margin-top:20px}
.ai-type-card{padding:14px 18px;border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;gap:14px;transition:all .35s;cursor:none}
.ai-type-card:hover,.ai-type-card.active{border-color:var(--border2);background:rgba(110,231,255,.03)}
.ai-type-icon{width:32px;height:32px;border-radius:8px;background:rgba(110,231,255,.06);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.ai-type-label{font-size:13px;font-weight:600;color:var(--white)}
.ai-type-sub{font-size:10px;color:rgba(255,255,255,.2);margin-top:2px;font-family:var(--font-mono)}
.ai-right-title{font-size:clamp(28px,3.5vw,44px);font-weight:800;letter-spacing:-2px;line-height:1.1;color:var(--white);margin-bottom:24px}
.ai-right-sub{font-size:14px;color:rgba(255,255,255,.25);line-height:1.9;margin-bottom:40px}
.ai-features{display:flex;flex-direction:column;gap:16px}
.ai-feature{display:flex;align-items:flex-start;gap:16px;padding:18px;border:1px solid var(--border);border-radius:12px;transition:all .35s}
.ai-feature:hover{border-color:var(--border2);transform:translateX(-8px)}
html[dir="ltr"] .ai-feature:hover{transform:translateX(8px)}
.ai-feature-icon{width:36px;height:36px;border-radius:10px;background:rgba(110,231,255,.06);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ai-feature-icon svg{width:18px;height:18px;stroke:var(--accent);fill:none;stroke-width:1.5}
.ai-feature-title{font-size:13px;font-weight:600;color:var(--white);margin-bottom:4px}
.ai-feature-desc{font-size:11px;color:rgba(255,255,255,.2);line-height:1.7}

/* ═══ PROCESS ═══ */
#process{padding:140px 72px}
.process-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:80px;position:relative}
.process-steps::before{content:'';position:absolute;top:50px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,var(--border),var(--border),var(--border),transparent)}
.process-step{display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 16px;position:relative;z-index:1}
.process-num-wrap{width:100px;height:100px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;background:var(--bg2);position:relative;transition:all .5s var(--ease2);margin-bottom:28px}
.process-step:hover .process-num-wrap{border-color:var(--border2);box-shadow:var(--glow-sm)}
.process-num-wrap::before{content:'';position:absolute;inset:-8px;border-radius:50%;border:1px dashed rgba(110,231,255,.04);animation:ringSpin 10s linear infinite}
.process-num{font-family:var(--font-mono);font-size:24px;font-weight:700;color:var(--accent);opacity:.4;transition:opacity .3s}
.process-step:hover .process-num{opacity:1}
.process-icon{width:32px;height:32px;display:flex;align-items:center;justify-content:center;position:absolute}
.process-icon svg{width:20px;height:20px;stroke:var(--accent);fill:none;stroke-width:1.5}
.process-title{font-size:14px;font-weight:700;color:var(--white);margin-bottom:8px}
.process-desc{font-size:11px;color:rgba(255,255,255,.2);line-height:1.8}

/* ═══ FOUNDERS (MINDS) ═══ */
#minds{padding:140px 72px}
.minds-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:80px}
.mind-card{position:relative;min-height:580px;overflow:hidden;cursor:none;border:1px solid var(--border)}
.mind-photo{position:absolute;inset:0;background-size:cover;background-position:center top;filter:grayscale(80%) brightness(.35) contrast(1.1);transition:all .7s var(--ease2)}
.mind-card:hover .mind-photo{filter:grayscale(20%) brightness(.5) contrast(1.05);transform:scale(1.04)}
.mind-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,5,5,.98) 0%,rgba(5,5,5,.7) 45%,transparent 80%)}
.mind-glow{position:absolute;bottom:0;left:0;right:0;height:300px;background:radial-gradient(ellipse 100% 60% at 50% 100%,rgba(110,231,255,.04) 0%,transparent 70%);opacity:0;transition:opacity .5s}
.mind-card:hover .mind-glow{opacity:1}
.mind-content{position:absolute;bottom:0;left:0;right:0;padding:48px 44px;z-index:2}
.mind-role-tag{display:inline-block;font-family:var(--font-mono);font-size:7px;letter-spacing:4px;color:var(--accent);text-transform:uppercase;margin-bottom:12px;padding:5px 12px;border:1px solid rgba(110,231,255,.15);border-radius:20px}
.mind-name{font-size:clamp(24px,3vw,34px);font-weight:800;color:var(--white);letter-spacing:-1px;margin-bottom:6px}
.mind-job{font-size:12px;color:rgba(255,255,255,.3);margin-bottom:20px;font-family:var(--font-en)}
.mind-divider{width:0;height:1px;background:linear-gradient(90deg,var(--accent),transparent);transition:width .6s var(--ease2);margin-bottom:16px}
.mind-card:hover .mind-divider{width:80px}
.mind-bio{font-size:12px;color:rgba(255,255,255,.25);line-height:1.9;max-height:0;overflow:hidden;opacity:0;transition:max-height .6s var(--ease2),opacity .5s}
.mind-card:hover .mind-bio{max-height:120px;opacity:1}
.mind-social{display:flex;gap:12px;margin-top:16px;opacity:0;transform:translateY(12px);transition:all .4s var(--ease2) .1s}
.mind-card:hover .mind-social{opacity:1;transform:none}
.mind-social a{width:32px;height:32px;border:1px solid rgba(255,255,255,.08);border-radius:50%;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);transition:all .3s;font-size:13px}
.mind-social a:hover{border-color:var(--accent);color:var(--accent)}
.mind-corner{position:absolute;width:20px;height:20px;border-color:rgba(110,231,255,.12);border-style:solid;pointer-events:none;z-index:3;transition:border-color .3s}
.mind-corner.tl{top:16px;right:16px;border-top-width:1px;border-right-width:1px}
html[dir="ltr"] .mind-corner.tl{right:auto;left:16px;border-right-width:0;border-left-width:1px}
.mind-card:hover .mind-corner{border-color:rgba(110,231,255,.3)}

/* ═══ ACHIEVEMENTS ═══ */
#impact{padding:140px 72px;background:var(--bg2)}
.impact-inner{display:flex;flex-direction:column;align-items:center;text-align:center}
.impact-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:80px;width:100%}
.impact-item{padding:52px 32px;border:1px solid var(--border);position:relative;overflow:hidden;background:var(--bg3);transition:all .4s var(--ease2)}
.impact-item::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);transform:scaleX(0);transition:transform .5s var(--ease2)}
.impact-item:hover::after{transform:scaleX(1)}
.impact-item:hover{transform:translateY(-6px);border-color:var(--border2);box-shadow:var(--glow-sm)}
.impact-num{font-size:clamp(48px,6vw,72px);font-weight:800;color:var(--white);line-height:1;font-family:var(--font-en);letter-spacing:-3px}
.impact-num span{background:linear-gradient(135deg,var(--accent),var(--glow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.impact-suffix{font-size:clamp(32px,4vw,48px);font-weight:800;background:linear-gradient(135deg,var(--accent),var(--glow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.impact-label{font-size:11px;color:rgba(255,255,255,.22);margin-top:8px;font-family:var(--font-mono);letter-spacing:2px;text-transform:uppercase}
.impact-bar{height:2px;background:rgba(110,231,255,.06);border-radius:1px;margin-top:24px;overflow:hidden}
.impact-bar-fill{height:100%;background:linear-gradient(90deg,var(--glow),var(--accent));transform:scaleX(0);transform-origin:right;transition:transform 1.2s var(--ease2)}
html[dir="ltr"] .impact-bar-fill{transform-origin:left}
.impact-item.visible .impact-bar-fill{transform:scaleX(1)}

/* ═══ WHY AURA ═══ */
#why{padding:140px 72px}
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;margin-top:80px;align-items:start}
.why-cards{display:flex;flex-direction:column;gap:16px}
.why-card{padding:28px 32px;border:1px solid var(--border);border-radius:var(--r);background:var(--bg2);transition:all .4s var(--ease2);cursor:none;position:relative;overflow:hidden}
.why-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at var(--mx,50%) var(--my,50%),rgba(110,231,255,.04) 0%,transparent 50%);opacity:0;transition:opacity .3s}
.why-card:hover::before{opacity:1}
.why-card:hover{border-color:var(--border2);transform:translateX(-8px)}
html[dir="ltr"] .why-card:hover{transform:translateX(8px)}
.why-card-icon{width:40px;height:40px;border-radius:10px;background:rgba(110,231,255,.06);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;margin-bottom:16px;transition:all .3s}
.why-card:hover .why-card-icon{border-color:var(--border2);background:rgba(110,231,255,.1)}
.why-card-icon svg{width:20px;height:20px;stroke:var(--accent);fill:none;stroke-width:1.5}
.why-card-title{font-size:15px;font-weight:700;color:var(--white);margin-bottom:6px}
.why-card-desc{font-size:12px;color:rgba(255,255,255,.22);line-height:1.8}
.why-right{position:sticky;top:120px}
.why-visual{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:40px;position:relative;overflow:hidden}
.why-visual::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.why-visual-title{font-size:13px;font-weight:700;color:var(--white);margin-bottom:28px}
.why-chart-bars{display:flex;flex-direction:column;gap:14px}
.why-bar-item{display:flex;flex-direction:column;gap:6px}
.why-bar-label{font-size:10px;color:rgba(255,255,255,.25);font-family:var(--font-mono);letter-spacing:2px;text-transform:uppercase}
.why-bar-track{height:4px;background:rgba(255,255,255,.04);border-radius:2px;overflow:hidden}
.why-bar-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--glow),var(--accent));transform:scaleX(0);transform-origin:right;transition:transform 1.4s var(--ease2)}
html[dir="ltr"] .why-bar-fill{transform-origin:left}
.why-visual.visible .why-bar-fill{transform:scaleX(1)}

/* ═══ TESTIMONIALS ═══ */
#testi{padding:140px 72px;background:var(--bg2)}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:80px}
.testi-card{padding:44px 36px;border:1px solid var(--border);background:var(--bg3);position:relative;overflow:hidden;transition:all .4s var(--ease2)}
.testi-card::before{content:'"';position:absolute;top:-10px;right:28px;font-size:120px;color:rgba(110,231,255,.04);font-family:var(--font-en);font-weight:800;line-height:1;pointer-events:none}
html[dir="ltr"] .testi-card::before{right:auto;left:28px}
.testi-card:hover{transform:translateY(-6px);border-color:var(--border2);box-shadow:var(--glow-sm)}
.testi-stars{display:flex;gap:4px;margin-bottom:20px}
.testi-stars span{color:var(--gold);font-size:11px}
.testi-text{font-size:13px;color:rgba(255,255,255,.35);line-height:1.9;margin-bottom:28px}
.testi-author{display:flex;align-items:center;gap:14px}
.testi-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,rgba(110,231,255,.15),rgba(167,139,250,.15));border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.testi-name{font-size:13px;font-weight:700;color:var(--white)}
.testi-role{font-size:10px;color:rgba(255,255,255,.2);font-family:var(--font-mono);letter-spacing:2px;margin-top:2px}

/* ═══ CONTACT / FINAL ═══ */
#contact{padding:160px 72px;text-align:center;position:relative;z-index:2}
.contact-orb{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(110,231,255,.04) 0%,transparent 65%);left:50%;top:50%;transform:translate(-50%,-50%);pointer-events:none;animation:heroOrbFloat 10s ease-in-out infinite alternate}
.contact-inner{position:relative;z-index:1}
.contact-title{font-size:clamp(40px,6vw,80px);font-weight:800;letter-spacing:-3px;color:var(--white);line-height:1;margin-bottom:24px}
.contact-title em{font-style:normal;background:linear-gradient(135deg,var(--accent),var(--glow),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.contact-sub{font-size:16px;color:rgba(255,255,255,.25);max-width:560px;margin:0 auto 56px;line-height:1.9}
.contact-btns{display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap}
.wa-btn{display:inline-flex;align-items:center;gap:12px;padding:18px 44px;background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;font-family:var(--font-en);font-size:10px;letter-spacing:3px;text-transform:uppercase;border:none;border-radius:40px;font-weight:700;transition:all .4s var(--ease2)}
.wa-btn:hover{transform:translateY(-4px);box-shadow:0 20px 60px rgba(37,211,102,.3)}
.wa-btn svg{width:18px;height:18px;fill:currentColor}

/* ═══ FOOTER ═══ */
footer{position:relative;z-index:2;border-top:1px solid var(--border)}
.footer-top{padding:72px 72px 48px;display:grid;grid-template-columns:280px 1fr 1fr 1fr;gap:48px}
.footer-brand .nav-logo-name{font-size:18px;letter-spacing:4px}
.footer-brand-sub{font-size:11px;color:rgba(255,255,255,.15);margin-top:12px;line-height:2;max-width:220px}
.footer-social{display:flex;gap:10px;margin-top:24px}
.footer-social a{width:34px;height:34px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.2);transition:all .3s;font-size:13px}
.footer-social a:hover{border-color:var(--accent);color:var(--accent);box-shadow:0 0 16px rgba(110,231,255,.15)}
.footer-col-title{font-family:var(--font-mono);font-size:7px;letter-spacing:4px;color:rgba(110,231,255,.4);text-transform:uppercase;margin-bottom:20px}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:12px}
.footer-col a{font-size:12px;color:rgba(255,255,255,.2);transition:color .3s}
.footer-col a:hover{color:var(--white)}
.footer-bottom{padding:20px 72px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);background:rgba(0,0,0,.2)}
.footer-copy{font-family:var(--font-mono);font-size:8px;color:rgba(255,255,255,.08);letter-spacing:2px}
.footer-bottom-links{display:flex;gap:24px}
.footer-bottom-links a{font-family:var(--font-en);font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.12);transition:color .3s}
.footer-bottom-links a:hover{color:var(--accent)}

/* ═══ MODAL ═══ */
#modal{position:fixed;inset:0;z-index:1000;display:none;align-items:center;justify-content:center;padding:20px}
#modal.open{display:flex}
.modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.96);backdrop-filter:blur(30px)}
.modal-box{position:relative;z-index:1;background:var(--bg2);border:1px solid var(--border);width:100%;max-width:560px;max-height:92vh;overflow-y:auto;animation:modalIn .5s var(--ease2);border-radius:var(--r2);scrollbar-width:thin;scrollbar-color:var(--border) transparent}
@keyframes modalIn{from{opacity:0;transform:translateY(20px) scale(.97)}to{opacity:1;transform:none}}
.modal-topbar{height:1.5px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.modal-header{padding:32px 40px 24px;border-bottom:1px solid var(--border)}
.modal-eyebrow{font-family:var(--font-mono);font-size:7px;letter-spacing:5px;color:var(--accent);text-transform:uppercase;display:block;margin-bottom:6px}
.modal-title{font-size:22px;font-weight:700}
.modal-close{position:absolute;top:20px;background:none;border:1px solid var(--border);color:rgba(255,255,255,.2);width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:10px;font-size:14px;transition:all .3s}
.modal-close:hover{border-color:var(--accent);color:var(--accent)}
html[dir="rtl"] .modal-close{left:20px}
html[dir="ltr"] .modal-close{right:20px}
.modal-body{padding:28px 40px 40px}
.person-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px}
.person-opt{border:1px solid var(--border);padding:16px;background:var(--bg3);transition:all .3s;border-radius:var(--r);cursor:none}
.person-opt:hover,.person-opt.sel{border-color:var(--border2);background:rgba(110,231,255,.03)}
.person-opt.sel{border-color:rgba(110,231,255,.2)}
.person-dot{width:6px;height:6px;border-radius:50%;border:1px solid rgba(255,255,255,.06);margin-bottom:8px;transition:all .3s}
.person-opt.sel .person-dot{background:var(--accent);border-color:var(--accent);box-shadow:0 0 12px rgba(110,231,255,.3)}
.person-role{font-family:var(--font-mono);font-size:7px;letter-spacing:3px;color:var(--accent);text-transform:uppercase;margin-bottom:2px}
.person-name{font-size:12px;font-weight:600}
.form-group{margin-bottom:16px}
.form-label{display:block;font-family:var(--font-mono);font-size:8px;letter-spacing:3px;color:rgba(255,255,255,.25);text-transform:uppercase;margin-bottom:8px}
.form-input,.form-textarea,.form-select{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--white);font-family:var(--font-ar);font-size:13px;padding:13px 16px;transition:border-color .3s;outline:none;border-radius:10px}
.form-input:focus,.form-textarea:focus,.form-select:focus{border-color:rgba(110,231,255,.25)}
.form-textarea{resize:vertical;min-height:90px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-select{appearance:none;cursor:none}
.btn-send{width:100%;padding:16px;background:var(--accent);color:var(--bg);font-family:var(--font-en);font-size:10px;letter-spacing:3px;text-transform:uppercase;border:none;font-weight:700;margin-top:8px;transition:all .35s var(--ease2);border-radius:10px;position:relative;overflow:hidden}
.btn-send:hover{transform:translateY(-2px);box-shadow:0 16px 48px rgba(110,231,255,.25)}
#modal-ok{display:none;text-align:center;padding:60px 40px;flex-direction:column;align-items:center;gap:16px}
#modal-ok.show{display:flex}
.ok-check{width:64px;height:64px;border-radius:50%;border:1px solid var(--accent);display:flex;align-items:center;justify-content:center;position:relative;margin-bottom:8px}
.ok-check::after{content:'';position:absolute;inset:-12px;border-radius:50%;border:1px solid rgba(110,231,255,.1);animation:okExpand 2s ease-out infinite}
@keyframes okExpand{0%{opacity:.5;transform:scale(1)}100%{opacity:0;transform:scale(1.6)}}
.ok-check svg{stroke:var(--accent);width:26px;height:26px;stroke-width:1.5;fill:none}
.ok-title{font-size:20px;font-weight:700}
.ok-text{font-size:12px;color:rgba(255,255,255,.25);line-height:2;max-width:300px}

/* ═══ RESPONSIVE ═══ */
@media(max-width:1200px){
  nav,nav.scrolled{padding:14px 40px}
  .section,#intro,#services,#ai-system,#process,#minds,#impact,#why,#testi,#contact{padding:120px 40px}
  #hero{padding:0 32px}
  .services-grid{grid-template-columns:repeat(3,1fr)}
  .impact-grid{grid-template-columns:repeat(2,1fr)}
  .testi-grid{grid-template-columns:repeat(2,1fr)}
  .footer-top{grid-template-columns:1fr 1fr;padding:56px 40px 40px}
  .footer-bottom{padding:18px 40px}
  .process-steps{grid-template-columns:repeat(3,1fr);row-gap:40px}
  .process-steps::before{display:none}
}
@media(max-width:1024px){
  .services-grid{grid-template-columns:repeat(2,1fr)}
  .ai-system-inner{grid-template-columns:1fr;gap:48px}
  .why-grid{grid-template-columns:1fr;gap:48px}
  .why-right{position:relative;top:auto}
  .minds-grid{grid-template-columns:1fr}
  .mind-card{min-height:480px}
  nav,nav.scrolled{padding:12px 32px}
  .footer-top{grid-template-columns:1fr 1fr}
}
@media(max-width:768px){
  nav,nav.scrolled{padding:10px 20px}
  .nav-links,.nav-cta-btn{display:none}
  .hamburger{display:flex}
  .section,#intro,#services,#ai-system,#process,#minds,#impact,#why,#testi,#contact{padding:100px 20px}
  #hero{padding:80px 20px 60px;min-height:100vh}
  .services-grid{grid-template-columns:1fr}
  .impact-grid{grid-template-columns:repeat(2,1fr)}
  .testi-grid{grid-template-columns:1fr}
  .person-grid{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
  .footer-top{grid-template-columns:1fr;text-align:center;padding:40px 20px 28px}
  .footer-bottom{padding:16px 20px;flex-direction:column;gap:10px;text-align:center}
  .footer-bottom-links{justify-content:center}
  .footer-social{justify-content:center}
  .process-steps{grid-template-columns:1fr;gap:32px}
  .process-steps::before{display:none}
}
@media(max-width:480px){
  .section,#intro,#services,#ai-system,#process,#minds,#impact,#why,#testi,#contact{padding:80px 14px}
  #hero{padding:60px 14px 40px}
  nav,nav.scrolled{padding:8px 14px}
  .hero-title{letter-spacing:-3px}
  .modal-box{max-width:100%}
  .modal-header,.modal-body{padding:20px 18px}
  .impact-grid{grid-template-columns:1fr 1fr}
}
html[dir="ltr"] .s-eyebrow-line{background:linear-gradient(90deg,var(--accent),transparent)}
html[dir="ltr"] .hero-eyebrow-line{background:linear-gradient(90deg,var(--accent),transparent)}
html[dir="ltr"] .mind-corner.tl{right:auto;left:16px;border-top-width:1px;border-left-width:1px;border-right-width:0}

/* ═══ EASING UPGRADES ═══ */
:root{
  --ease3: cubic-bezier(0.16,1,0.3,1);
  --ease4: cubic-bezier(0.25,1,0.5,1);
  --ease5: cubic-bezier(0.4,0,0.2,1);
}

/* ═══ HIDE MUSIC BUTTON ═══ */
/* ═══ ENHANCED REVEAL ANIMATIONS ═══ */
.reveal{
  opacity:0;transform:translateY(48px) scale(.98);
  transition:opacity 1.1s var(--ease3),transform 1.1s var(--ease3);
}
.reveal.visible{opacity:1;transform:translateY(0) scale(1)}
.reveal-l{
  opacity:0;transform:translateX(-60px) scale(.98);
  transition:opacity 1.1s var(--ease3),transform 1.1s var(--ease3);
}
.reveal-l.visible{opacity:1;transform:none}
.reveal-r{
  opacity:0;transform:translateX(60px) scale(.98);
  transition:opacity 1.1s var(--ease3),transform 1.1s var(--ease3);
}
.reveal-r.visible{opacity:1;transform:none}
.reveal-scale{
  opacity:0;transform:scale(.88);
  transition:opacity 1.2s var(--ease3),transform 1.2s var(--ease3);
}
.reveal-scale.visible{opacity:1;transform:none}

/* ═══ ENHANCED SERVICE CARDS ═══ */
.svc-card{
  transition:transform .7s var(--ease3),border-color .5s,box-shadow .7s var(--ease3),background .4s;
}
.svc-card:hover{transform:translateY(-8px) scale(1.01)}

/* ═══ PURE LOGO — NO BACKGROUND ═══ */
/* Hide all orbit rings so nothing appears behind the logo */
.hero-orbit-ring,.hero-orbit-dot{display:none}

.hero-logo-wrap{
  position:relative;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:44px;
  animation:fadeUp 1.4s var(--ease3) .1s both;
}
.hero-brand-logo{
  width:560px;max-width:90vw;
  display:block;
  position:relative;z-index:2;
  mix-blend-mode:screen;
  filter:brightness(1.15) contrast(1.1);
  animation:logoBreathe 6s ease-in-out infinite;
  pointer-events:none;
}
@keyframes logoBreathe{
  0%,100%{
    filter:brightness(1.1) contrast(1.1);
    drop-shadow: 0 0 0px rgba(110,231,255,0);
  }
  50%{
    filter:brightness(1.25) contrast(1.15);
    drop-shadow: 0 0 40px rgba(110,231,255,.15);
  }
}

/* ═══ PRELOADER LOGO — BIGGER & CLEAN ═══ */
.pre-logo-aura{
  width:200px;height:200px;
  border-radius:0;border:none;background:none;
  box-shadow:none;animation:none;
  display:flex;align-items:center;justify-content:center;
}
.pre-logo-aura::before,.pre-logo-aura::after{display:none}
.pre-logo-img{
  width:200px;height:auto;object-fit:contain;
  mix-blend-mode:screen;
  filter:brightness(1.15) contrast(1.1);
  animation:preLogoIn 1.2s var(--ease3) .3s both;
}
@keyframes preLogoIn{
  from{opacity:0;transform:scale(.75) translateY(20px)}
  to{opacity:1;transform:none}
}

/* ═══ FOUNDERS — CINEMATIC CARDS ═══ */
.minds-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
  margin-top:80px;
}
.mind-card{
  position:relative;
  min-height:680px;
  overflow:hidden;
  cursor:none;
  border:1px solid rgba(110,231,255,.07);
  border-radius:20px;
  transition:transform .9s var(--ease3),border-color .6s,box-shadow .9s var(--ease3);
}
.mind-card:hover{
  transform:translateY(-10px) scale(1.015);
  border-color:rgba(110,231,255,.14);
  box-shadow:0 40px 80px rgba(0,0,0,.5),0 0 60px rgba(110,231,255,.06);
}
.mind-photo{
  position:absolute;inset:0;
  background-size:cover;background-position:center top;
  filter:grayscale(55%) brightness(.42) contrast(1.15) saturate(0.8);
  transition:filter 1s var(--ease3),transform 1s var(--ease3);
}
.mind-card:hover .mind-photo{
  filter:grayscale(10%) brightness(.56) contrast(1.1) saturate(1.1);
  transform:scale(1.06);
}
/* Fallback — geometric pattern when no photo */
.mind-fallback{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 70% 60% at 50% 30%,rgba(110,231,255,.05) 0%,transparent 70%),
    radial-gradient(ellipse 50% 80% at 80% 60%,rgba(167,139,250,.04) 0%,transparent 60%);
  display:flex;align-items:center;justify-content:center;
}
.mind-geo{
  position:absolute;top:18%;left:50%;transform:translateX(-50%);
  width:160px;height:160px;
  border-radius:50%;
  border:1px solid rgba(110,231,255,.08);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 80px rgba(110,231,255,.05);
}
.mind-geo::before{
  content:'';position:absolute;inset:-16px;border-radius:50%;
  border:1px dashed rgba(110,231,255,.05);
  animation:ringSpin 14s linear infinite;
}
.mind-geo::after{
  content:'';position:absolute;inset:-32px;border-radius:50%;
  border:1px solid rgba(110,231,255,.03);
  animation:ringSpin 20s linear infinite reverse;
}
.mind-geo svg{
  width:52px;height:52px;stroke:rgba(110,231,255,.3);
  fill:none;stroke-width:1;stroke-linecap:round;
}
.mind-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(5,5,5,.97) 0%,rgba(5,5,5,.75) 40%,rgba(5,5,5,.15) 70%,transparent 90%);
}
.mind-glow{
  position:absolute;bottom:0;left:0;right:0;height:360px;
  background:radial-gradient(ellipse 90% 50% at 50% 100%,rgba(110,231,255,.05) 0%,transparent 70%);
  opacity:0;transition:opacity .8s var(--ease3);
}
.mind-card:hover .mind-glow{opacity:1}
.mind-content{
  position:absolute;bottom:0;left:0;right:0;padding:52px 48px;z-index:3;
}
.mind-role-tag{
  display:inline-block;
  font-family:var(--font-mono);font-size:7px;letter-spacing:5px;
  color:var(--accent);text-transform:uppercase;
  margin-bottom:14px;padding:6px 14px;
  border:1px solid rgba(110,231,255,.15);border-radius:20px;
  backdrop-filter:blur(10px);background:rgba(110,231,255,.04);
}
.mind-name{
  font-size:clamp(26px,3.2vw,38px);font-weight:800;
  color:var(--white);letter-spacing:-1.5px;margin-bottom:6px;
  line-height:1;
}
.mind-job{
  font-size:12px;color:rgba(255,255,255,.28);
  margin-bottom:22px;font-family:var(--font-en);letter-spacing:.5px;
}
.mind-divider{
  width:0;height:1px;
  background:linear-gradient(90deg,var(--accent),transparent);
  transition:width .8s var(--ease3);margin-bottom:18px;
}
.mind-card:hover .mind-divider{width:100px}
.mind-bio{
  font-size:13px;color:rgba(255,255,255,.28);line-height:1.9;
  max-height:0;overflow:hidden;opacity:0;
  transition:max-height .8s var(--ease3),opacity .6s var(--ease3);
}
.mind-card:hover .mind-bio{max-height:160px;opacity:1}
.mind-social{
  display:flex;gap:12px;margin-top:18px;
  opacity:0;transform:translateY(16px);
  transition:opacity .6s var(--ease3) .1s,transform .6s var(--ease3) .1s;
}
.mind-card:hover .mind-social{opacity:1;transform:none}
.mind-social a{
  width:36px;height:36px;border:1px solid rgba(255,255,255,.08);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  color:rgba(255,255,255,.3);transition:all .4s var(--ease3);
}
.mind-social a:hover{border-color:var(--accent);color:var(--accent);box-shadow:0 0 20px rgba(110,231,255,.2)}
.mind-corner{
  position:absolute;width:22px;height:22px;border-color:rgba(110,231,255,.12);
  border-style:solid;pointer-events:none;z-index:3;
  transition:border-color .6s var(--ease3),width .6s var(--ease3),height .6s var(--ease3);
}
.mind-card:hover .mind-corner{border-color:rgba(110,231,255,.35);width:28px;height:28px}
.mind-corner.tl{top:20px;right:20px;border-top-width:1px;border-right-width:1px;border-left-width:0;border-bottom-width:0}
html[dir="ltr"] .mind-corner.tl{right:auto;left:20px;border-right-width:0;border-left-width:1px}

/* ═══ HERO TEXT & BUTTON TRANSITIONS ═══ */
.hero-title{transition:opacity .4s}
.btn-primary{transition:transform .5s var(--ease3),box-shadow .5s var(--ease3),background .3s}
.btn-primary:hover{transform:translateY(-4px) scale(1.03);box-shadow:0 24px 60px rgba(110,231,255,.28)}
.btn-ghost{transition:all .5s var(--ease3)}
.btn-ghost:hover{transform:translateY(-3px)}

/* ═══ WHY CARDS — SMOOTHER ═══ */
.why-card{transition:all .6s var(--ease3)}
.why-card:hover{transform:translateX(-10px)}
html[dir="ltr"] .why-card:hover{transform:translateX(10px)}

/* ═══ IMPACT ITEMS ═══ */
.impact-item{transition:all .6s var(--ease3)}
.impact-item:hover{transform:translateY(-8px)}

/* ═══ TESTIMONIALS ═══ */
.testi-card{transition:all .6s var(--ease3)}
.testi-card:hover{transform:translateY(-8px)}

/* ═══ PROCESS STEPS ═══ */
.process-num-wrap{transition:all .6s var(--ease3)}

/* ═══ SCROLL SMOOTHNESS ═══ */
html{scroll-behavior:smooth;scroll-padding-top:80px}

/* ═══ SECTION FADE-IN ON LOAD ═══ */
@keyframes sectionIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
#hero .hero-inner{animation:sectionIn 1.4s var(--ease3) .8s both}

/* ═══ AI PANEL ANIMATION ═══ */
.ai-panel{transition:all .7s var(--ease3)}
.ai-feature{transition:all .5s var(--ease3)}

/* ═══ NAV LOGO — IMAGE ONLY ═══ */
.nav-logo-only{
  height:48px;width:auto;max-width:160px;
  object-fit:contain;display:block;
  mix-blend-mode:screen;
  filter:brightness(1.2) contrast(1.1);
  transition:filter .4s var(--ease2),transform .4s var(--ease2);
}
.nav-logo:hover .nav-logo-only{
  filter:brightness(1.4) contrast(1.15);
  transform:scale(1.04);
}

/* ═══ CINEMATIC INTRO SCREEN ═══ */
#cinematic-intro{
  position:fixed;inset:0;z-index:100000;
  background:#000;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;
  overflow:hidden;
  transition:opacity 1.6s cubic-bezier(.16,1,.3,1),visibility 1.6s;
}
#cinematic-intro.exit{opacity:0;visibility:hidden;pointer-events:none}

/* Horizontal scan lines — film effect */
.ci-scanlines{
  position:absolute;inset:0;pointer-events:none;z-index:1;
  background:repeating-linear-gradient(
    0deg,
    transparent,transparent 2px,
    rgba(255,255,255,.012) 2px,rgba(255,255,255,.012) 4px
  );
}
/* Vignette */
.ci-vignette{
  position:absolute;inset:0;z-index:1;pointer-events:none;
  background:radial-gradient(ellipse 80% 70% at 50% 50%,transparent 40%,rgba(0,0,0,.9) 100%);
}
/* Horizontal bars — letterbox */
.ci-bar-top,.ci-bar-bot{
  position:absolute;left:0;right:0;height:0;background:#000;z-index:2;
  transition:height 1.4s cubic-bezier(.16,1,.3,1);
}
.ci-bar-top{top:0}
.ci-bar-bot{bottom:0}
#cinematic-intro.letterbox .ci-bar-top,
#cinematic-intro.letterbox .ci-bar-bot{height:80px}

/* Center content */
.ci-center{
  position:relative;z-index:3;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:0;opacity:0;transform:scale(.88);
  transition:opacity 1.2s var(--ease2),transform 1.2s var(--ease2);
}
.ci-center.show{opacity:1;transform:scale(1)}

/* Logo */
.ci-logo-wrap{
  position:relative;margin-bottom:44px;
  display:flex;align-items:center;justify-content:center;
}
.ci-logo{
  width:520px;max-width:88vw;
  mix-blend-mode:screen;
  filter:brightness(1.2) contrast(1.15);
  opacity:0;transform:scale(.8) translateY(20px);
  transition:opacity 1.4s var(--ease2),transform 1.4s var(--ease2);
}
.ci-logo.show{opacity:1;transform:scale(1) translateY(0)}

/* Light sweep on logo */
.ci-logo-sweep{
  position:absolute;inset:0;
  background:linear-gradient(90deg,transparent 0%,rgba(110,231,255,.06) 50%,transparent 100%);
  transform:translateX(-100%);
  animation:ciSweep 3s ease-in-out 1.8s infinite;
  pointer-events:none;
}
@keyframes ciSweep{
  0%{transform:translateX(-100%);opacity:0}
  10%{opacity:1}
  90%{opacity:1}
  100%{transform:translateX(200%);opacity:0}
}

/* Company name text CREATIVE DESIGN MOTION style — horizontal scroll */
.ci-marquee-wrap{
  width:100vw;overflow:hidden;
  margin-bottom:32px;
  opacity:0;
  transition:opacity .8s var(--ease2);
}
.ci-marquee-wrap.show{opacity:1}
.ci-marquee-track{
  display:flex;white-space:nowrap;
  animation:ciMarquee 12s linear infinite;
}
.ci-marquee-item{
  display:inline-block;
  font-family:'Space Grotesk',sans-serif;
  font-size:clamp(48px,8vw,100px);
  font-weight:800;
  letter-spacing:-4px;
  text-transform:uppercase;
  padding-right:80px;
  color:transparent;
  -webkit-text-stroke: 1px rgba(110,231,255,.12);
}
.ci-marquee-item.filled{
  -webkit-text-stroke:0;
  color:rgba(255,255,255,.06);
}
@keyframes ciMarquee{
  from{transform:translateX(0)}
  to{transform:translateX(-50%)}
}

/* Digital Services tagline */
.ci-tagline{
  font-family:'Space Grotesk',sans-serif;
  font-size:clamp(10px,1.4vw,14px);
  font-weight:400;
  letter-spacing:10px;
  text-transform:uppercase;
  color:rgba(110,231,255,.0);
  margin-top:0;
  opacity:0;
  transition:opacity 1s var(--ease2);
  position:relative;
}
.ci-tagline.show{opacity:1;color:rgba(110,231,255,.55)}
.ci-tagline::before,.ci-tagline::after{
  content:'—';
  margin:0 16px;
  color:rgba(110,231,255,.25);
}

/* Divider line */
.ci-line{
  width:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(110,231,255,.4),transparent);
  margin:28px auto;
  transition:width 1.4s var(--ease2);
}
.ci-line.show{width:280px}

/* Touch prompt */
.ci-touch-prompt{
  font-family:'JetBrains Mono',monospace;
  font-size:9px;
  letter-spacing:5px;
  text-transform:uppercase;
  color:rgba(255,255,255,.2);
  margin-top:48px;
  opacity:0;
  animation:ciPulse 2.4s ease-in-out 3s infinite;
  cursor:pointer;
  transition:opacity .6s;
}
.ci-touch-prompt.show{opacity:1}
@keyframes ciPulse{
  0%,100%{opacity:.2;transform:scale(1)}
  50%{opacity:.6;transform:scale(1.03)}
}

/* Particle orbs in intro */
.ci-orb{
  position:absolute;border-radius:50%;pointer-events:none;z-index:0;
  animation:ciOrbFloat var(--dur,10s) ease-in-out infinite alternate;
}
@keyframes ciOrbFloat{
  from{transform:translate(0,0) scale(1)}
  to{transform:translate(var(--tx,20px),var(--ty,-20px)) scale(1.1)}
}

/* ══════════════════════════════════════
   🔥 EPIC ANIMATIONS — الأنيميشن التهبيلة
   ══════════════════════════════════════ */

/* ─── 1. GLITCH TEXT على hero title ─── */
.hero-title{position:relative}
.hero-title-accent{
  position:relative;
  display:inline-block;
  animation:glitchHover 6s ease-in-out 2s infinite;
}
@keyframes glitchHover{
  0%,90%,100%{
    filter:none;
    transform:none;
    text-shadow:none;
  }
  91%{
    filter:none;
    transform:skewX(-2deg);
    text-shadow:3px 0 rgba(110,231,255,.7),-3px 0 rgba(167,139,250,.7);
  }
  92%{
    filter:none;
    transform:skewX(2deg) translateX(-4px);
    text-shadow:-3px 0 rgba(110,231,255,.9),3px 0 rgba(167,139,250,.9);
  }
  93%{
    transform:none;
    text-shadow:none;
    filter:brightness(1.6) saturate(1.8);
  }
  94%{
    transform:skewX(-1deg) translateX(3px);
    text-shadow:2px 0 rgba(110,231,255,.5),-2px 0 rgba(167,139,250,.5);
    filter:none;
  }
  95%,100%{transform:none;text-shadow:none;filter:none}
}

/* ─── 2. MAGNETIC FLOAT على service cards ─── */
.svc-card{
  transform-style:preserve-3d;
  will-change:transform;
}
/* يتحرك عالماوس عبر JS */

/* ─── 3. SPOTLIGHT TRAIL — أثر الضوء وراء الكيرسور ─── */
#spotlight-trail{
  position:fixed;inset:0;pointer-events:none;z-index:99996;
  mix-blend-mode:screen;
  overflow:hidden;
}
.trail-dot{
  position:absolute;
  border-radius:50%;
  pointer-events:none;
  transform:translate(-50%,-50%);
  background:radial-gradient(circle,rgba(110,231,255,.18) 0%,transparent 60%);
  animation:trailFade .6s ease-out forwards;
}
@keyframes trailFade{
  0%{opacity:1;width:var(--s,80px);height:var(--s,80px)}
  100%{opacity:0;width:calc(var(--s,80px)*2.5);height:calc(var(--s,80px)*2.5)}
}

/* ─── 4. LIQUID MORPH على الـ hero orb ─── */
.hero-bg-orb{
  animation:heroOrbFloat 8s ease-in-out infinite alternate,
            liquidMorph 12s ease-in-out infinite;
}
@keyframes liquidMorph{
  0%,100%{border-radius:60% 40% 55% 45% / 50% 60% 40% 50%}
  25%{border-radius:40% 60% 45% 55% / 60% 40% 60% 40%}
  50%{border-radius:55% 45% 60% 40% / 40% 55% 45% 60%}
  75%{border-radius:45% 55% 40% 60% / 55% 45% 55% 45%}
}

/* ─── 5. TEXT REVEAL CINEMATIC — كل عنوان section ─── */
.s-title{
  overflow:hidden;
  position:relative;
}
.s-title::after{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(90deg,var(--bg) 0%,transparent 100%);
  transform:translateX(0);
  transition:transform 1.2s cubic-bezier(.16,1,.3,1);
  pointer-events:none;
}
.s-title.visible::after{
  transform:translateX(101%);
}

/* ─── 6. NEON BORDER PULSE على service cards ─── */
@keyframes neonPulse{
  0%,100%{box-shadow:0 0 0px rgba(110,231,255,0),inset 0 0 0px rgba(110,231,255,0)}
  50%{box-shadow:0 0 30px rgba(110,231,255,.08),inset 0 0 15px rgba(110,231,255,.03)}
}
.svc-card:nth-child(odd){animation:neonPulse 4s ease-in-out infinite}
.svc-card:nth-child(even){animation:neonPulse 4s ease-in-out 2s infinite}

/* ─── 7. COUNTER MORPH — الأرقام بتـ morph ─── */
.impact-num{
  position:relative;
  overflow:hidden;
}
.impact-num::before{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(135deg,rgba(110,231,255,.06) 0%,transparent 60%);
  animation:counterGlow 3s ease-in-out infinite;
}
@keyframes counterGlow{
  0%,100%{opacity:0;transform:scaleX(.3)}
  50%{opacity:1;transform:scaleX(1)}
}

/* ─── 8. HORIZONTAL SCROLL SECTIONS — elements ─── */
.process-step{transition:transform .9s cubic-bezier(.16,1,.3,1),opacity .9s}
.process-step:hover{transform:translateY(-12px) scale(1.03)}
.process-step:hover .process-num{
  background:linear-gradient(135deg,rgba(110,231,255,.15),rgba(167,139,250,.1));
  border-color:rgba(110,231,255,.25);
}

/* ─── 9. PARTICLES BURST onclick ─── */
#burst-canvas{
  position:fixed;inset:0;pointer-events:none;z-index:99995;
}

/* ─── 10. TYPING CURSOR على preloader status ─── */
.pre-status::after{
  content:'_';
  animation:blinkCursor .6s step-end infinite;
  color:var(--accent);
}
@keyframes blinkCursor{0%,100%{opacity:1}50%{opacity:0}}

/* ─── 11. REVEAL — CLIP PATH cinematic ─── */
.reveal-clip{
  opacity:0;
  clip-path:inset(0 100% 0 0);
  transition:clip-path 1s cubic-bezier(.16,1,.3,1),opacity .3s;
}
.reveal-clip.visible{
  opacity:1;
  clip-path:inset(0 0% 0 0);
}

/* ─── 12. SCROLL PROGRESS GLOW ─── */
#spfill{
  box-shadow:0 0 20px 2px rgba(110,231,255,.25),0 0 40px 4px rgba(110,231,255,.1);
}

/* ─── 13. MIND CARD HOLOGRAM ─── */
.mind-card::before{
  content:'';
  position:absolute;inset:0;z-index:4;
  background:linear-gradient(135deg,transparent 40%,rgba(110,231,255,.025) 50%,transparent 60%);
  transform:translateX(-100%) skewX(-10deg);
  transition:transform 0s;
  pointer-events:none;
}
.mind-card:hover::before{
  transform:translateX(200%) skewX(-10deg);
  transition:transform 1.2s cubic-bezier(.16,1,.3,1);
}

/* ─── 14. FOOTER LOGO FLOAT ─── */
.footer-brand .nav-logo-only{
  animation:footerLogoFloat 4s ease-in-out infinite;
  filter:brightness(1.1) contrast(1.05);
}
@keyframes footerLogoFloat{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-6px)}
}

/* ─── 15. WHY CARDS — 3D TILT ─── */
.why-card{
  transform-style:preserve-3d;
  transition:transform .6s var(--ease3),border-color .4s,box-shadow .6s;
}
.why-card:hover{
  transform:perspective(800px) rotateX(-4deg) rotateY(4deg) translateY(-8px) scale(1.02);
  border-color:rgba(110,231,255,.18);
  box-shadow:0 24px 60px rgba(0,0,0,.4),0 0 40px rgba(110,231,255,.07);
}

/* ─── 16. HERO STATS HOVER ─── */
.hero-stat:hover .hero-stat-num{
  animation:statPop .4s var(--ease3);
}
@keyframes statPop{
  0%{transform:scale(1)}
  50%{transform:scale(1.2);text-shadow:0 0 30px rgba(110,231,255,.6)}
  100%{transform:scale(1)}
}

/* ─── 17. NAV scroll glow ─── */
nav.scrolled{
  box-shadow:0 2px 40px rgba(0,0,0,.6),0 1px 0 rgba(110,231,255,.04);
}

/* ─── 18. CTA BTN PARTICLE BURST ─── */
.btn-primary::after{
  content:'';
  position:absolute;
  inset:0;
  border-radius:inherit;
  background:radial-gradient(circle at var(--bx,50%) var(--by,50%),rgba(255,255,255,.2) 0%,transparent 60%);
  opacity:0;
  transition:opacity .4s;
}
.btn-primary:active::after{
  opacity:1;
  transition:opacity 0s;
}

/* ═══ MARQUEE SEPARATOR ═══ */
.marquee-sep{
  position:relative;
  width:100%;
  overflow:hidden;
  padding:0;
