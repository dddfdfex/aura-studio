/* ═══ MUSIC BUTTON (corner) ═══ */
#music-fab{
  position:fixed;
  bottom:32px; right:32px;
  z-index:600;
  width:52px; height:52px;
  border-radius:50%;
  background:rgba(5,5,5,.85);
  border:1px solid rgba(110,231,255,.15);
  backdrop-filter:blur(20px);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer;
  opacity:0; visibility:hidden;
  transform:translateY(20px) scale(.8);
  transition:all .5s cubic-bezier(.16,1,.3,1);
  box-shadow:0 8px 32px rgba(0,0,0,.5);
  outline:none;
}
#music-fab.show{
  opacity:1; visibility:visible;
  transform:translateY(0) scale(1);
}
#music-fab:hover{
  border-color:rgba(110,231,255,.35);
  box-shadow:0 0 0 8px rgba(110,231,255,.06),0 12px 40px rgba(0,0,0,.5);
  transform:scale(1.08);
}
#music-fab svg{
  width:20px;height:20px;
  stroke:rgba(110,231,255,.7);
  fill:none;stroke-width:1.5;
  transition:all .3s;
}
#music-fab.playing svg{ stroke:rgba(110,231,255,1); }
/* pulse ring when playing */
#music-fab.playing::before{
  content:'';
  position:absolute;
  inset:-8px; border-radius:50%;
  border:1px solid rgba(110,231,255,.2);
  animation:fabPulse 1.8s ease-out infinite;
}
#music-fab.playing::after{
  content:'';
  position:absolute;
  inset:-16px; border-radius:50%;
  border:1px solid rgba(110,231,255,.1);
  animation:fabPulse 1.8s ease-out .4s infinite;
}
@keyframes fabPulse{
  0%{transform:scale(.9);opacity:.8}
  100%{transform:scale(1.4);opacity:0}
}

