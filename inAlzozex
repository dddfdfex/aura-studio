/* ─── CLIP REVEAL on s-title ─── */
(function(){
  var titles=document.querySelectorAll('.s-title');
  var obs2=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('visible'); obs2.unobserve(e.target); }
    });
  },{threshold:.15});
  titles.forEach(function(t){ obs2.observe(t); });
})();

/* ─── SCROLL-LINKED HERO PARALLAX (enhanced) ─── */
window.addEventListener('scroll',function(){
  var sy=window.scrollY;
  var orb=document.querySelector('.hero-bg-orb');
  var title=document.querySelector('.hero-title');
  var stats=document.querySelector('.hero-stats');
  if(orb) orb.style.transform='translate(-50%,'+(-20+sy*.05)+'px) scale('+(1+sy*.0002)+')';
  if(title) title.style.transform='translateY('+(sy*.12)+'px)';
  if(stats) stats.style.transform='translateY('+(sy*.06)+'px)';
},{passive:true});

/* ─── SECTION ENTRY — STAGGER CHILDREN ─── */
(function(){
  var sectObs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(!e.isIntersecting) return;
      var children=e.target.querySelectorAll('.svc-card,.why-card,.process-step,.impact-item,.mind-card');
      children.forEach(function(c,i){
        c.style.transitionDelay=(i*.07)+'s';
      });
      sectObs.unobserve(e.target);
    });
  },{threshold:.05});
  document.querySelectorAll('#services,#why,#process,#impact,#minds').forEach(function(s){sectObs.observe(s);});
})();
</script>
