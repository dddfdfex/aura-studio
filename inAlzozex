/* ─── LANGUAGE ─── */
var cLang = 'ar';
function toggleLang(){
  cLang = cLang==='ar' ? 'en' : 'ar';
  var html = document.documentElement;
  if(cLang==='en'){ html.lang='en'; html.dir='ltr'; document.getElementById('lang-lbl').textContent='العربية'; }
  else { html.lang='ar'; html.dir='rtl'; document.getElementById('lang-lbl').textContent='English'; }
  document.querySelectorAll('[data-'+cLang+']').forEach(function(el){ var t=el.getAttribute('data-'+cLang); if(t) el.textContent=t; });
  document.querySelectorAll('[data-'+cLang+'-placeholder]').forEach(function(el){ el.placeholder=el.getAttribute('data-'+cLang+'-placeholder'); });
}

/* ─── HERO STATS QUICK COUNT ─── */
var heroStats = document.querySelectorAll('.hero-stat-num[data-count]');
setTimeout(function(){
  heroStats.forEach(function(el){
    var target = parseInt(el.getAttribute('data-count'));
    var cur = 0, step = target / 60;
    var t = setInterval(function(){
      cur += step;
      if(cur >= target){ cur = target; clearInterval(t); }
      el.textContent = Math.floor(cur) + '+';
    }, 24);
  });
}, 1800);


/* ═══ MUSIC FAB ENGINE ═══ */
var _musicPlaying = false;
var _musicStarted = false;

function startMusicFadeIn(){
  var audio = document.getElementById('bg-music');
  if(!audio) return;
  audio.volume = 0;
  audio.play().then(function(){
    _musicPlaying = true;
    _musicStarted = true;
    var fab = document.getElementById('music-fab');
    if(fab) fab.classList.add('playing');
    /* fade in volume */
    var vol = 0;
    var fi = setInterval(function(){
      vol = Math.min(vol + 0.012, 0.4);
      audio.volume = vol;
      if(vol >= 0.4) clearInterval(fi);
    }, 80);
  }).catch(function(){
    /* autoplay blocked — FAB still shows, user can click */
    _musicStarted = true;
  });
}

function toggleMusicFab(){
  var audio = document.getElementById('bg-music');
  var fab   = document.getElementById('music-fab');
  if(!audio || !fab) return;
  if(!_musicStarted){
    startMusicFadeIn();
    return;
  }
  if(audio.paused){
    audio.play().then(function(){
      _musicPlaying = true;
      fab.classList.add('playing');
    }).catch(function(){});
  } else {
    audio.pause();
    _musicPlaying = false;
    fab.classList.remove('playing');
  }
}

function showMusicFab(){
  var fab = document.getElementById('music-fab');
  if(fab) setTimeout(function(){ fab.classList.add('show'); }, 900);
}

