  font-size:clamp(36px,5.5vw,72px);
  color:rgba(255,255,255,.88);
  letter-spacing:-1px;
}
.ms-row1 .marquee-sep-item.outline{
  color:transparent;
  -webkit-text-stroke:1.5px rgba(255,255,255,.18);
}
/* row 2 — أصغر، inverse direction */
.ms-row2 .marquee-sep-item{
  font-size:clamp(32px,4.8vw,64px);
  color:rgba(255,255,255,.88);
  letter-spacing:-1px;
}
.ms-row2 .marquee-sep-item.outline{
