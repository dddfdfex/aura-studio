/* ─── SPOTLIGHT TRAIL ─── */
(function(){
  var trail = document.getElementById('spotlight-trail');
  if(!trail) return;
  var mx=0,my=0,lastX=0,lastY=0;
  document.addEventListener('mousemove',function(e){
    mx=e.clientX; my=e.clientY;
    var dx=mx-lastX, dy=my-lastY, dist=Math.sqrt(dx*dx+dy*dy);
    if(dist>18){
      lastX=mx; lastY=my;
      var dot=document.createElement('div');
      dot.className='trail-dot';
      var sz=Math.min(60+dist*1.5,160);
      dot.style.cssText='left:'+mx+'px;top:'+my+'px;--s:'+sz+'px;width:'+sz+'px;height:'+sz+'px';
      trail.appendChild(dot);
      setTimeout(function(){if(dot.parentNode)dot.parentNode.removeChild(dot);},650);
    }
  },{passive:true});
})();

/* ─── PARTICLE BURST on click ─── */
(function(){
  var bc=document.getElementById('burst-canvas');
  if(!bc) return;
  var ctx=bc.getContext('2d');
  bc.width=window.innerWidth; bc.height=window.innerHeight;
  window.addEventListener('resize',function(){bc.width=window.innerWidth;bc.height=window.innerHeight;});
  var particles=[];
  function spawnBurst(x,y){
    var colors=['rgba(110,231,255,','rgba(167,139,250,','rgba(255,255,255,'];
    for(var i=0;i<20;i++){
      var angle=Math.random()*Math.PI*2;
      var speed=Math.random()*4+1.5;
      particles.push({
        x:x,y:y,
        vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed,
        r:Math.random()*3+1,
        life:1,
        decay:Math.random()*.035+.02,
        color:colors[Math.floor(Math.random()*colors.length)]
      });
    }
  }
  document.addEventListener('click',function(e){spawnBurst(e.clientX,e.clientY);});
  document.addEventListener('touchstart',function(e){
    if(e.touches[0]) spawnBurst(e.touches[0].clientX,e.touches[0].clientY);
  },{passive:true});
  function animBurst(){
    ctx.clearRect(0,0,bc.width,bc.height);
    particles=particles.filter(function(p){return p.life>0});
    particles.forEach(function(p){
      p.x+=p.vx; p.y+=p.vy;
      p.vy+=0.08;
      p.vx*=0.97; p.life-=p.decay;
      ctx.beginPath();
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=p.color+p.life+')';
      ctx.shadowBlur=8; ctx.shadowColor=p.color+'0.8)';
      ctx.fill();
      ctx.shadowBlur=0;
    });
    requestAnimationFrame(animBurst);
  }
  animBurst();
})();

/* ─── 3D MAGNETIC TILT on service cards ─── */
document.querySelectorAll('.svc-card').forEach(function(card){
  card.addEventListener('mousemove',function(e){
    var r=card.getBoundingClientRect();
    var cx=r.left+r.width/2, cy=r.top+r.height/2;
    var dx=(e.clientX-cx)/r.width*2, dy=(e.clientY-cy)/r.height*2;
    card.style.transform='translateY(-8px) scale(1.01) perspective(600px) rotateX('+(-dy*6)+'deg) rotateY('+(dx*6)+'deg)';
    card.style.setProperty('--mx',((e.clientX-r.left)/r.width*100)+'%');
    card.style.setProperty('--my',((e.clientY-r.top)/r.height*100)+'%');
  });
  card.addEventListener('mouseleave',function(){
    card.style.transform='';
  });
});

/* ─── 3D TILT on why cards ─── */
document.querySelectorAll('.why-card').forEach(function(card){
  card.addEventListener('mousemove',function(e){
    var r=card.getBoundingClientRect();
