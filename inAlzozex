/* ─── CURSOR ─── */
(function(){
  var dot = document.getElementById('cur-dot');
  var ring = document.getElementById('cur-ring');
  var glow = document.getElementById('cur-glow');
  var mx = 0, my = 0, rx = 0, ry = 0, gx = 0, gy = 0;
  document.addEventListener('mousemove', function(e){
    mx = e.clientX; my = e.clientY;
    dot.style.left = mx + 'px'; dot.style.top = my + 'px';
  });
  function animCursor(){
    rx += (mx - rx) * 0.14; ry += (my - ry) * 0.14;
    gx += (mx - gx) * 0.06; gy += (my - gy) * 0.06;
    ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
    glow.style.left = gx + 'px'; glow.style.top = gy + 'px';
    requestAnimationFrame(animCursor);
  }
  animCursor();
})();

/* ─── CANVAS PARTICLE UNIVERSE ─── */
(function(){
  var canvas = document.getElementById('universe-canvas');
  var ctx = canvas.getContext('2d');
  var W, H, particles = [], mouseX = 0, mouseY = 0;
  function resize(){ W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize);
  document.addEventListener('mousemove', function(e){ mouseX = e.clientX; mouseY = e.clientY; });
  for(var i = 0; i < 80; i++){
    particles.push({
      x: Math.random() * 2000, y: Math.random() * 1200,
      vx: (Math.random() - .5) * .18, vy: (Math.random() - .5) * .18,
      r: Math.random() * 1.4 + .2, a: Math.random() * .15 + .02,
      glow: Math.random() > .8
    });
  }
  var t = 0;
  function draw(){
    ctx.clearRect(0, 0, W, H);
    // Aurora gradient layers
    var a1 = ctx.createRadialGradient(W*.2, H*.3, 0, W*.2, H*.3, W*.6);
    a1.addColorStop(0, 'rgba(110,231,255,0.015)'); a1.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = a1; ctx.fillRect(0,0,W,H);
    var a2 = ctx.createRadialGradient(W*.8, H*.7, 0, W*.8, H*.7, W*.5);
    a2.addColorStop(0, 'rgba(167,139,250,0.01)'); a2.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = a2; ctx.fillRect(0,0,W,H);
    // Mouse glow
    var mg = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, 300);
    mg.addColorStop(0, 'rgba(110,231,255,0.018)'); mg.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = mg; ctx.fillRect(0,0,W,H);
    // Particles
    particles.forEach(function(p){
      p.x += p.vx; p.y += p.vy;
      if(p.x < 0) p.x = W; if(p.x > W) p.x = 0;
      if(p.y < 0) p.y = H; if(p.y > H) p.y = 0;
      var pulse = p.glow ? (Math.sin(t * .03 + p.x) * .5 + .5) * .1 + .02 : p.a;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
      if(p.glow){
        ctx.fillStyle = 'rgba(110,231,255,' + pulse + ')';
        ctx.shadowBlur = 12; ctx.shadowColor = 'rgba(110,231,255,.4)';
      } else {
        ctx.fillStyle = 'rgba(200,230,255,' + p.a + ')';
        ctx.shadowBlur = 0;
      }
      ctx.fill();
      ctx.shadowBlur = 0;
    });
    // Connect nearby particles
    for(var i = 0; i < particles.length; i++){
      for(var j = i+1; j < particles.length; j++){
        var dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
        var dist = Math.sqrt(dx*dx + dy*dy);
        if(dist < 120){
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.strokeStyle = 'rgba(110,231,255,' + (.04 * (1 - dist/120)) + ')';
          ctx.lineWidth = .5; ctx.stroke();
        }
      }
    }
    t++;
    requestAnimationFrame(draw);
  }
  draw();
})();

/* ─── PRELOADER ─── */
(function(){
  var fill = document.getElementById('pre-fill');
  var num = document.getElementById('pre-num');
  var status = document.getElementById('pre-status');
  var msgs = ['بنحضّر الماكينة', 'بنولّع الكون', 'بنشغّل الإضاءة', 'بنمشي الموشن', 'هنبدأ دلوقتي'];
  var pct = 0, step = 0;
  function tick(){
    pct += Math.random() * 2.5 + .5;
    if(pct > 100) pct = 100;
    fill.style.width = pct + '%';
    num.textContent = Math.floor(pct) + '%';
    var si = Math.floor(pct / 21);
    if(si < msgs.length) status.textContent = msgs[si];
    if(pct < 100){ setTimeout(tick, 28); }
    else {
      setTimeout(function(){
        document.getElementById('preloader').classList.add('gone');
        initCinematicIntro();
      }, 700);
    }
  }
  setTimeout(tick, 300);
})();

/* ═══ CINEMATIC INTRO ENGINE ═══ */
var introExited = false;
function initCinematicIntro(){
  var intro = document.getElementById('cinematic-intro');
  var center = document.getElementById('ci-center');
  var logo = document.getElementById('ci-logo');
  var line = document.getElementById('ci-line');
  var tagline = document.getElementById('ci-tagline');
  var marquee = document.getElementById('ci-marquee');
  var prompt = document.getElementById('ci-touch-prompt');

  /* Step 1 — Letterbox bars */
  intro.classList.add('letterbox');

  /* Step 2 — Show marquee */
  setTimeout(function(){ marquee.classList.add('show'); }, 300);

  /* Step 3 — Show center content */
  setTimeout(function(){ center.classList.add('show'); }, 500);

  /* Step 4 — Animate logo in */
  setTimeout(function(){ if(logo) logo.classList.add('show'); }, 700);

  /* Step 5 — Line */
  setTimeout(function(){ line.classList.add('show'); }, 1400);

  /* Step 6 — Tagline */
  setTimeout(function(){ tagline.classList.add('show'); }, 1800);

  /* Step 7 — Touch prompt */
  setTimeout(function(){ prompt.classList.add('show'); }, 2600);

  /* Touch / click / scroll to exit */
  function doExit(){
    if(introExited) return;
    introExited = true;
    prompt.style.opacity = '0';
    intro.classList.remove('letterbox');
    setTimeout(function(){
      intro.classList.add('exit');
      initReveal();
      showMusicFab();
      startMusicFadeIn();
    }, 200);
    setTimeout(function(){
      intro.style.display = 'none';
    }, 2200);
  }

  intro.addEventListener('click', doExit);
  intro.addEventListener('touchstart', doExit, {passive:true});
  window.addEventListener('keydown', function(e){ if(e.key && !introExited) doExit(); }, {once:true});

  /* Auto-exit after 8s */
  setTimeout(function(){ if(!introExited) doExit(); }, 8000);
}



/* ─── SCROLL PROGRESS ─── */
window.addEventListener('scroll', function(){
  var s = window.scrollY, h = document.body.scrollHeight - window.innerHeight;
  document.getElementById('spfill').style.width = (h > 0 ? (s/h)*100 : 0) + '%';
  var nav = document.getElementById('nav');
  if(s > 60) nav.classList.add('scrolled'); else nav.classList.remove('scrolled');
}, { passive: true });

/* ─── REVEAL ON SCROLL ─── */
function initReveal(){
  var els = document.querySelectorAll('.reveal,.reveal-l,.reveal-r,.reveal-scale');
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        var delay = parseFloat(e.target.dataset.delay || 0);
        setTimeout(function(){ e.target.classList.add('visible'); }, delay * 1000);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: .1 });
  els.forEach(function(el){ obs.observe(el); });
}

