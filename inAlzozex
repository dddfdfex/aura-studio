/* ─── COUNTER ANIMATION ─── */
var counters = [{ id:'c1', target:200 }, { id:'c2', target:50 }, { id:'c3', target:5 }, { id:'c4', target:98 }];
var countersStarted = false;
function startCounters(){
  if(countersStarted) return; countersStarted = true;
  counters.forEach(function(c){
    var el = document.getElementById(c.id);
    if(!el) return;
    var cur = 0, dur = 2000, step = c.target / (dur/16);
    var t = setInterval(function(){
      cur += step;
      if(cur >= c.target){ cur = c.target; clearInterval(t); }
      el.textContent = Math.floor(cur);
    }, 16);
  });
}
var impactObs = new IntersectionObserver(function(entries){
  if(entries[0].isIntersecting){ startCounters(); impactObs.disconnect(); }
}, { threshold: .2 });
var impactEl = document.getElementById('impact');
if(impactEl) impactObs.observe(impactEl);

